{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022", "DOM"],
    "declaration": true,
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "paths": {
      "@sardegna/shared": ["./packages/shared/src/index.ts"]
    },
    "resolveJsonModule": true
  },
  "exclude": ["node_modules", "dist", "build"]
}
